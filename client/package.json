{
  "name": "survey-app-client",
  "version": "0.1.0",
  "private": true,
  "proxy": "http://localhost:5002",
  "dependencies": {
    "axios": "^1.3.0",
    "chart.js": "^4.2.1",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.5",
    "react-icons": "^5.6.0",
    "react-quill-new": "^3.8.3",
    "react-router-dom": "^6.8.0"
  },
  "scripts": {
    "start": "cross-env NODE_OPTIONS=--no-deprecation craco start",
    "build": "cross-env NODE_OPTIONS=--no-deprecation craco build",
    "build:prerender": "cross-env NODE_OPTIONS=--no-deprecation craco build && react-snap",
    "test": "cross-env NODE_OPTIONS=--no-deprecation craco test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@craco/craco": "^7.1.0",
    "autoprefixer": "^10.5.0",
    "cross-env": "^10.1.0",
    "postcss": "^8.5.10",
    "react-scripts": "5.0.1",
    "react-snap": "^1.23.0",
    "tailwindcss": "^3.4.13"
  },
  "reactSnap": {
    "inlineCss": true,
    "source": "build",
    "include": [
      "/",
      "/articles",
      "/surveys",
      "/training",
      "/consulting",
      "/media"
    ]
  },
  "overrides": {
    "webpack-dev-server": "^4.15.2"
  }
}
