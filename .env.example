# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=insightforge
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_SSL=false

# Server Configuration
SERVER_PORT=5000
NODE_ENV=development
TRUST_PROXY=0

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRE=1h

# CORS / rate limiting
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20

# Client Configuration (frontend build/runtime)
REACT_APP_API_URL=http://localhost:5000/api

# SMTP (optional, for submission emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=InsightForge
